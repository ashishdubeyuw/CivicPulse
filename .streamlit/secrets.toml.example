# Streamlit Secrets Template
# Copy this to .streamlit/secrets.toml and fill in your actual values
# secrets.toml is in .gitignore - never commit real secrets!

# OpenAI API Configuration (if extending the report to be interactive)
openai_api_key = "sk-..."

# Database Configuration (if integrating with backend)
database_url = "postgresql://user:password@localhost/civicpulse"
database_pool_size = 10

# GitHub Configuration (for repo links)
github_token = "ghp_..."
github_repo = "Meerxn/civic-pulse"

# Streamlit Cloud Secrets
# Available as st.secrets["key_name"] in app
